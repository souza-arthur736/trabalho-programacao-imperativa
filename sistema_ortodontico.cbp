<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
    <FileVersion major="1" minor="6" />
    <Project>
        <Option title="Sistema Ortodontico" />
        <Option pch_mode="2" />
        <Option compiler="gcc" />
        <Build>
            <Target title="Debug">
                <Option output="bin/Debug/sistema_ortodontico" prefix_auto="1" extension_auto="1" />
                <Option object_output="obj/Debug/" />
                <Option type="1" />
                <Option compiler="gcc" />
                <Compiler>
                    <Add option="-g" />
                    <Add option="-Wall" />
                    <Add option="`pkg-config --cflags gtk4`" />
                </Compiler>
                <Linker>
                    <Add option="`pkg-config --libs gtk4`" />
                </Linker>
            </Target>
            <Target title="Release">
                <Option output="bin/Release/sistema_ortodontico" prefix_auto="1" extension_auto="1" />
                <Option object_output="obj/Release/" />
                <Option type="1" />
                <Option compiler="gcc" />
                <Compiler>
                    <Add option="-O2" />
                    <Add option="-Wall" />
                    <Add option="`pkg-config --cflags gtk4`" />
                </Compiler>
                <Linker>
                    <Add option="`pkg-config --libs gtk4`" />
                </Linker>
            </Target>
        </Build>
        <Compiler>
            <Add option="-Wall" />
        </Compiler>
        <Unit filename="main.c">
            <Option compilerVar="CC" />
        </Unit>
        <Unit filename="login.c">
            <Option compilerVar="CC" />
        </Unit>
        <Unit filename="frontend.c">
            <Option compilerVar="CC" />
        </Unit>
        <Unit filename="repositorio.c">
            <Option compilerVar="CC" />
        </Unit>
        <Unit filename="validacao.c">
            <Option compilerVar="CC" />
        </Unit>
        <Unit filename="analise_ortodontica.c">
            <Option compilerVar="CC" />
        </Unit>
        <Unit filename="mcnamara.h" />
        <Extensions>
            <code_completion />
            <envvars />
            <debugger />
        </Extensions>
    </Project>
</CodeBlocks_project_file>
